{
  "name": "The Visual Sanctuary Dark",
  "type": "dark",
  "colors": {
    "editor.background": "#1a1b26",
    "editor.foreground": "#cfc9c2",
    "editor.lineHighlightBackground": "#1e202e",
    "editorCursor.foreground": "#7aa2f7",
    "sideBar.background": "#16161e",
    "sideBar.foreground": "#cfc9c2",
    "sideBar.border": "#1a1b26",
    "activityBar.background": "#16161e",
    "activityBar.foreground": "#7aa2f7",
    "activityBar.inactiveForeground": "#3b4261",
    "activityBar.border": "#1a1b26",
    "editorGroupHeader.tabsBackground": "#16161e",
    "editorGroupHeader.tabsBorder": "#1a1b26",
    "tab.activeBackground": "#1a1b26",
    "tab.activeForeground": "#cfc9c2",
    "tab.activeBorderTop": "#7aa2f7",
    "tab.inactiveBackground": "#16161e",
    "tab.inactiveForeground": "#565f89",
    "tab.border": "#16161e",
    "editorWidget.background": "#16161e",
    "editorWidget.border": "#3b4261",
    "statusBar.background": "#16161e",
    "statusBar.foreground": "#565f89",
    "statusBar.border": "#1a1b26",
    "editorLineNumber.foreground": "#3b4261",
    "editorLineNumber.activeForeground": "#737aa2",
    "editorIndentGuide.background1": "#1e202e",
    "editorIndentGuide.activeBackground1": "#3b4261",
    "editor.selectionBackground": "#28344a",
    "editor.findMatchBackground": "#3d59a166",
    "editor.findMatchHighlightBackground": "#3d59a133",
    "terminal.background": "#1a1b26",
    "terminal.foreground": "#cfc9c2",
    "terminalCursor.foreground": "#7aa2f7",
    "terminal.selectionBackground": "#28344a",
    "terminal.inactiveSelectionBackground": "#1e202e",
    "quickInput.background": "#16161e",
    "quickInput.foreground": "#cfc9c2",
    "quickInputList.focusBackground": "#28344a",
    "list.activeSelectionBackground": "#28344a",
    "list.activeSelectionForeground": "#cfc9c2",
    "list.hoverBackground": "#1e202e"
  },
  "tokenColors": [
    {
      "name": "Funciones",
      "scope": [
        "entity.name.function",
        "support.function",
        "variable.function",
        "meta.function-call",
        "entity.name.method"
      ],
      "settings": {
        "foreground": "#7aa2f7",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "storage.type",
        "storage.modifier",
        "keyword.control",
        "keyword.control.flow",
        "keyword.operator.new",
        "keyword.operator.expression",
        "keyword.operator.logical"
      ],
      "settings": {
        "foreground": "#9d7cd8",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Cadenas",
      "scope": [
        "string",
        "punctuation.definition.string",
        "string.template",
        "punctuation.definition.string.template"
      ],
      "settings": {
        "foreground": "#9ece6a"
      }
    },
    {
      "name": "Números y Booleanos",
      "scope": [
        "constant.numeric",
        "constant.language.boolean"
      ],
      "settings": {
        "foreground": "#ff9e64"
      }
    },
    {
      "name": "Comentarios",
      "scope": [
        "comment",
        "punctuation.definition.comment",
        "string.quoted.docstring.multi.python"
      ],
      "settings": {
        "foreground": "#737aa2",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Vars",
      "scope": [
        "variable",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#cfc9c2"
      }
    },
    {
      "name": "Propiedades",
      "scope": [
        "variable.other.property",
        "meta.object-literal.key",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#73daca"
      }
    },
    {
      "name": "Tipos",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class",
        "entity.name.type.interface",
        "entity.name.type.alias"
      ],
      "settings": {
        "foreground": "#2ac3de"
      }
    },
    {
      "name": "Componentes React",
      "scope": [
        "entity.name.tag",
        "support.class.component"
      ],
      "settings": {
        "foreground": "#e0af68"
      }
    },
    {
      "name": "JSX Props",
      "scope": [
        "entity.other.attribute-name",
        "meta.tag.attributes",
        "variable.other.jsx"
      ],
      "settings": {
        "foreground": "#9d7cd8",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Parámetros",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#bb9af7",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Constantes y Escapes",
      "scope": [
        "constant.other",
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#f7768e"
      }
    },
    {
      "name": "Decoradores/Anotaciones",
      "scope": [
        "meta.decorator",
        "entity.name.function.decorator",
        "punctuation.decorator"
      ],
      "settings": {
        "foreground": "#bb9af7"
      }
    },
    {
      "name": "Nombres de Espacio/Modulos",
      "scope": [
        "entity.name.namespace",
        "entity.name.type.module",
        "storage.modifier.package"
      ],
      "settings": {
        "foreground": "#7aa2f7",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp"
      ],
      "settings": {
        "foreground": "#f7768e"
      }
    },
    {
      "name": "Markdown Headings",
      "scope": [
        "markup.heading",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#7aa2f7",
        "fontStyle": "bold"
      }
    }
  ],
  "semanticHighlighting": true,
  "semanticTokenColors": {
    "variable.readonly": "#ff9e64",
    "type": "#2ac3de",
    "class": "#2ac3de",
    "method": "#7aa2f7",
    "property": "#73daca",
    "parameter": "#bb9af7",
    "function": "#7aa2f7"
  }
}