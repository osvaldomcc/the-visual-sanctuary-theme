            "fontStyle": "bold"
          }
        }
      ]
    }
  },
  "editor.semanticTokenColorCustomizations": {
    "[Default Light Modern]": {
      "enabled": true,
      "rules": {
        "variable.readonly": "#a65400",
        "type": "#007a8c",
        "interface": "#007a8c",
        "class": "#007a8c",
        "method": "#2d539e",
        "property": "#425e79",
        "parameter": "#0a6e4d",
        "function": "#2d539e"
      }
    },
    "[Default Dark Modern]": {
      "enabled": true,
      "rules": {
        "variable.readonly": "#ff9e64",
        "type": "#2ac3de",
        "class": "#2ac3de",
        "method": "#7aa2f7",
        "property": "#73daca",
        "parameter": "#bb9af7",
        "function": "#7aa2f7"
      }
    }
  },
  // General editor settings
  "editor.fontFamily": "'SF Mono Ligatures', 'SF Mono', Cascadia Code, monospace",
  "editor.fontLigatures": "'ss01', 'ss02', 'ss03', 'ss04', 'ss05', 'ss06', 'ss07', 'ss08', 'calt', 'liga'",
  "editor.fontSize": 14,
  "editor.lineHeight": 24,
  "editor.letterSpacing": 0.4,
  "editor.fontWeight": "400",
  "workbench.iconTheme": "symbols",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.cursorBlinking": "expand",
  "editor.cursorWidth": 2,
  "editor.minimap.enabled": true,
  "editor.bracketPairColorization.enabled": true,
  "editor.padding.top": 16,
  "editor.padding.bottom": 16,
  "editor.stickyScroll.enabled": true,
  "editor.scrollbar.vertical": "auto",
  "editor.scrollbar.horizontal": "auto",
  "workbench.list.horizontalScrolling": true,
  "editor.smoothScrolling": true,
  "editor.mouseWheelScrollSensitivity": 1.2,
  "editor.guides.indentation": true,
  "editor.renderLineHighlight": "all",
  "editor.renderLineHighlightOnlyWhenFocus": true,
  "workbench.list.smoothScrolling": true,
  "workbench.activityBar.location": "top",
  "workbench.sideBar.location": "right",
  "workbench.tree.indent": 22,
  "workbench.tree.renderIndentGuides": "always",
  "workbench.statusBar.visible": true,
  "editor.semanticHighlighting.enabled": true,
  "explorer.compactFolders": false,
  "update.mode": "manual",
  "extensions.autoUpdate": false,
  "redhat.telemetry.enabled": false,
  "workbench.colorTheme": "Default Light Modern",
  "window.autoDetectColorScheme": true,
  "workbench.reduceMotion": "auto",
  "git.blame.editorDecoration.enabled": true,
  // Formatting and linting
  "editor.formatOnSave": true,
  "eslint.format.enable": true,
  "editor.linkedEditing": true,
  "[typescriptreact]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint"
  },
  "[typescript]": {
    "editor.defaultFormatter": "dbaeumer.vscode-eslint"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "workbench.preferredDarkColorTheme": "Default Dark Modern",
  "diffEditor.renderSideBySide": true
}
