        },
        {
          "name": "Componentes React",
          "scope": ["entity.name.tag", "support.class.component"],
          "settings": {
            "foreground": "#e0af68"
          }
        },
        {
          "name": "JSX Props",
          "scope": [
            "entity.other.attribute-name",
            "meta.tag.attributes",
            "variable.other.jsx"
          ],
          "settings": {
            "foreground": "#9d7cd8",
