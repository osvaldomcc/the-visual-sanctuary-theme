  "editor.tokenColorCustomizations": {
    // Light mode token colors (Scientifically tuned for #f2f0e9 background - High legibility, low eye strain)
    "[Default Light Modern]": {
      "textMateRules": [
        {
          "name": "Funciones",
          "scope": [
            "entity.name.function",
            "support.function",
            "variable.function",
            "meta.function-call",
            "entity.name.method"
          ],
          "settings": {
            "foreground": "#2d539e",
            "fontStyle": "bold"
          }
        },
        {
          "name": "Estructuras/Keywords",
          "scope": [
            "keyword",
            "storage.type",
            "storage.modifier",
            "keyword.control",
            "keyword.control.flow",
            "keyword.operator.new",
            "keyword.operator.expression",
            "keyword.operator.logical"
          ],
          "settings": {
            "foreground": "#7c5295"
          }
        },
        {
          "name": "Cadenas de texto",
          "scope": [
            "string",
            "punctuation.definition.string",
            "string.template",
            "punctuation.definition.string.template"
          ],
          "settings": {
            "foreground": "#4b7a47"
          }
        },
        {
          "name": "Números y Booleanos",
          "scope": ["constant.numeric", "constant.language.boolean"],
          "settings": {
            "foreground": "#b15c00"
          }
        },
        {
          "name": "Comentarios",
          "scope": [
            "comment",
            "punctuation.definition.comment",
            "string.quoted.docstring.multi.python"
          ],
          "settings": {
            "foreground": "#4f5258",
            "fontStyle": "italic"
          }
        },
        {
          "name": "Variables",
          "scope": ["variable", "meta.definition.variable"],
          "settings": {
            "foreground": "#282c34"
          }
        },
        {
          "name": "Propiedades de Objetos",
          "scope": [
            "variable.other.property",
            "meta.object-literal.key",
            "support.type.property-name"
          ],
          "settings": {
            "foreground": "#425e79"
          }
        },
        {
          "name": "Tipos y Clases",
          "scope": [
            "entity.name.type",
            "entity.name.class",
            "support.type",
            "support.class",
            "entity.name.type.interface",
            "entity.name.type.alias"
          ],
          "settings": {
            "foreground": "#007a8c"
          }
        },
        {
          "name": "Componentes React",
          "scope": ["entity.name.tag", "support.class.component"],
          "settings": {
            "foreground": "#b14a00"
          }
        },
        {
          "name": "JSX Props",
          "scope": [
            "entity.other.attribute-name",
            "meta.tag.attributes",
            "variable.other.jsx"
          ],
          "settings": {
            "foreground": "#7c5295",
            "fontStyle": "italic"
          }
        },
        {
          "name": "Parámetros",
          "scope": ["variable.parameter"],
          "settings": {
            "foreground": "#0a6e4d",
            "fontStyle": "italic"
          }
        },
        {
          "name": "Constantes y Escapes",
          "scope": ["constant.other", "constant.character.escape"],
          "settings": {
            "foreground": "#a63c3c"
          }
        },
        {
          "name": "Decoradores/Anotaciones",
          "scope": [
            "meta.decorator",
            "entity.name.function.decorator",
            "punctuation.decorator"
          ],
          "settings": {
            "foreground": "#9a358c"
          }
        },
        {
          "name": "Nombres de Espacio/Modulos",
          "scope": [
            "entity.name.namespace",
            "entity.name.type.module",
            "storage.modifier.package"
          ],
          "settings": {
            "foreground": "#15428a",
            "fontStyle": "bold"
          }
        },
        {
          "name": "Regex",
          "scope": ["string.regexp"],
          "settings": {
            "foreground": "#a63c3c"
          }
        },
        {
          "name": "Markdown Headings",
          "scope": ["markup.heading", "entity.name.section"],
          "settings": {
            "foreground": "#2d539e",
            "fontStyle": "bold"
          }
        }
      ]
    },
    // Dark mode token colors (Tokyo Night-based, scientifically tuned for #1a1b26 background)
    "[Default Dark Modern]": {
      "textMateRules": [
        {
          "name": "Funciones",
          "scope": [
